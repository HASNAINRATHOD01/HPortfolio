<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hasnain Rathod — Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #05080f;
  --bg2: #090d16;
  --bg3: #0e1420;
  --bg4: #131922;
  --accent: #4fffb0;
  --accent2: #7c6fff;
  --accent3: #ff6b9d;
  --text: #e2e8f0;
  --muted: #4a5568;
  --muted2: #718096;
  --border: rgba(255,255,255,0.06);
  --border2: rgba(255,255,255,0.1);
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'JetBrains Mono', monospace;
  overflow-x: hidden;
  cursor: default;
}

/* CURSOR */
.cursor {
  width: 8px; height: 8px;
  background: var(--accent);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9999;
  transition: transform 0.1s;
}
.cursor-ring {
  width: 32px; height: 32px;
  border: 1px solid rgba(79,255,176,0.3);
  border-radius: 50%;
  position: fixed;
  pointer-events: none;
  z-index: 9998;
  transition: all 0.15s ease;
}

/* SCROLLBAR */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: #1a2030; border-radius: 2px; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; justify-content: space-between; align-items: center;
  padding: 1.4rem 5rem;
  background: rgba(5,8,15,0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
}
.nav-logo {
  font-family: 'Syne', sans-serif;
  font-weight: 800; font-size: 1.1rem;
  color: var(--accent); letter-spacing: 0.05em;
}
.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a {
  color: var(--muted2); text-decoration: none;
  font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
  transition: color 0.2s; position: relative;
}
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0;
  height: 1px; background: var(--accent);
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.3s;
}
.nav-links a:hover { color: var(--accent); }
.nav-links a:hover::after { transform: scaleX(1); }
.nav-cta {
  background: transparent; border: 1px solid rgba(79,255,176,0.3);
  color: var(--accent); padding: 0.5rem 1.2rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem; letter-spacing: 0.1em;
  border-radius: 4px; cursor: pointer; text-decoration: none;
  transition: all 0.2s;
}
.nav-cta:hover { background: rgba(79,255,176,0.08); }
.nav-cv {
  background: var(--accent); color: #05080f;
  padding: 0.5rem 1.2rem;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.72rem; letter-spacing: 0.1em;
  border-radius: 4px; cursor: pointer; text-decoration: none;
  transition: all 0.2s; font-weight: 600;
}
.nav-cv:hover { background: #3ae09a; transform: translateY(-1px); }
.btn-cv {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(79,255,176,0.08);
  border: 1px solid rgba(79,255,176,0.35);
  color: var(--accent);
  padding: 0.85rem 2rem; border-radius: 6px;
  text-decoration: none; font-size: 0.8rem;
  letter-spacing: 0.06em; transition: all 0.2s;
}
.btn-cv:hover { background: rgba(79,255,176,0.15); border-color: var(--accent); transform: translateY(-2px); }

/* HERO */
.hero {
  min-height: 100vh; display: flex; align-items: center;
  padding: 0 5rem; position: relative; overflow: hidden;
}
.hero-bg-lines {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(79,255,176,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(79,255,176,0.02) 1px, transparent 1px);
  background-size: 80px 80px;
}
.hero-bg-circle {
  position: absolute; width: 700px; height: 700px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(79,255,176,0.04) 0%, transparent 65%);
  right: -100px; top: 50%; transform: translateY(-50%);
  pointer-events: none;
}
.hero-bg-circle2 {
  position: absolute; width: 400px; height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(124,111,255,0.05) 0%, transparent 65%);
  left: 20%; top: 20%;
  pointer-events: none;
}
.hero-left { position: relative; z-index: 1; max-width: 720px; }
.hero-status {
  display: inline-flex; align-items: center; gap: 8px;
  font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--accent); border: 1px solid rgba(79,255,176,0.2);
  padding: 0.45rem 1rem; border-radius: 100px; margin-bottom: 2rem;
  animation: fadeUp 0.7s ease both;
}
.status-dot {
  width: 6px; height: 6px; background: var(--accent);
  border-radius: 50%; animation: pulse 2s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}
.hero-name {
  font-family: 'Syne', sans-serif;
  font-size: clamp(3.5rem, 8vw, 6.5rem);
  font-weight: 800; line-height: 0.92;
  letter-spacing: -0.04em; margin-bottom: 1.5rem;
  animation: fadeUp 0.7s 0.1s ease both;
}
.hero-name .line1 { display: block; color: var(--text); }
.hero-name .line2 {
  display: block;
  background: linear-gradient(135deg, var(--accent) 0%, var(--accent2) 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero-tagline {
  font-size: 0.9rem; color: var(--muted2); margin-bottom: 0.5rem;
  letter-spacing: 0.05em; animation: fadeUp 0.7s 0.2s ease both;
}
.hero-tagline span { color: var(--accent2); }
.hero-desc {
  font-size: 0.82rem; line-height: 2; color: #4a5568;
  max-width: 560px; margin-bottom: 3rem;
  animation: fadeUp 0.7s 0.3s ease both;
}
.hero-actions {
  display: flex; gap: 1rem; flex-wrap: wrap;
  animation: fadeUp 0.7s 0.4s ease both;
}
.btn-main {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--accent); color: #05080f;
  padding: 0.85rem 2rem; border-radius: 6px;
  text-decoration: none; font-weight: 500; font-size: 0.8rem;
  letter-spacing: 0.06em; transition: all 0.2s;
}
.btn-main:hover { background: #3ae09a; transform: translateY(-2px); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1px solid var(--border2); color: var(--muted2);
  padding: 0.85rem 2rem; border-radius: 6px;
  text-decoration: none; font-size: 0.8rem;
  letter-spacing: 0.06em; transition: all 0.2s;
}
.btn-ghost:hover { border-color: rgba(79,255,176,0.3); color: var(--accent); transform: translateY(-2px); }
.hero-scroll {
  position: absolute; bottom: 2.5rem; left: 5rem;
  display: flex; align-items: center; gap: 10px;
  font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase;
  color: var(--muted); animation: fadeUp 0.7s 0.6s ease both;
}
.scroll-line { width: 40px; height: 1px; background: var(--muted); }

/* SECTION BASE */
section { padding: 7rem 5rem; position: relative; }
.sec-eyebrow {
  font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 0.6rem;
  display: flex; align-items: center; gap: 10px;
}
.sec-eyebrow::before {
  content: ''; width: 24px; height: 1px; background: var(--accent);
}
.sec-title {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 800; letter-spacing: -0.03em; margin-bottom: 4rem;
  color: var(--text);
}

/* ABOUT */
.about-section { background: var(--bg2); }
.about-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;
}
.about-text { font-size: 0.85rem; line-height: 2.1; color: var(--muted2); }
.about-text p { margin-bottom: 1.2rem; }
.about-text strong { color: var(--accent); font-weight: 500; }
.about-stats {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
}
.stat-box {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 1.5rem;
  transition: border-color 0.2s;
}
.stat-box:hover { border-color: rgba(79,255,176,0.2); }
.stat-num {
  font-family: 'Syne', sans-serif;
  font-size: 2.5rem; font-weight: 800;
  color: var(--accent); letter-spacing: -0.03em;
  line-height: 1;
}
.stat-label { font-size: 0.72rem; color: var(--muted2); margin-top: 0.5rem; letter-spacing: 0.05em; }

/* SKILLS */
.skills-wrap { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.2rem; }
.skill-box {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 12px; padding: 1.8rem;
  transition: all 0.25s; position: relative; overflow: hidden;
}
.skill-box::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0; transition: opacity 0.3s;
}
.skill-box:hover { border-color: rgba(79,255,176,0.15); transform: translateY(-3px); }
.skill-box:hover::before { opacity: 1; }
.skill-icon { font-size: 1.5rem; margin-bottom: 1rem; }
.skill-cat {
  font-family: 'Syne', sans-serif; font-size: 0.78rem; font-weight: 700;
  color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase;
  margin-bottom: 1.2rem;
}
.tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.tag {
  background: rgba(79,255,176,0.05); border: 1px solid rgba(79,255,176,0.1);
  color: var(--muted2); padding: 0.3rem 0.75rem;
  border-radius: 4px; font-size: 0.72rem; letter-spacing: 0.04em;
  transition: all 0.2s;
}
.tag:hover { background: rgba(79,255,176,0.1); color: var(--accent); border-color: rgba(79,255,176,0.3); }

/* PROJECTS */
.projects-section { background: var(--bg2); }
.projects-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.proj-card {
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 14px; padding: 2.2rem;
  transition: all 0.25s; position: relative; overflow: hidden;
  display: flex; flex-direction: column;
}
.proj-card:hover { border-color: rgba(79,255,176,0.15); transform: translateY(-5px); }
.proj-card:hover .proj-arrow { transform: translate(3px, -3px); }
.proj-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.2rem; }
.proj-num { font-size: 0.65rem; color: var(--muted); letter-spacing: 0.15em; }
.proj-arrow { font-size: 1.1rem; color: var(--muted); transition: transform 0.2s; text-decoration: none; }
.proj-arrow:hover { color: var(--accent); }
.proj-title {
  font-family: 'Syne', sans-serif; font-size: 1.15rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.8rem; letter-spacing: -0.02em;
}
.proj-desc { font-size: 0.78rem; line-height: 1.9; color: var(--muted2); margin-bottom: 1.5rem; flex: 1; }
.proj-tech { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.proj-tech span {
  background: rgba(124,111,255,0.08); border: 1px solid rgba(124,111,255,0.15);
  color: #7c6fff; padding: 0.25rem 0.7rem;
  border-radius: 4px; font-size: 0.68rem; letter-spacing: 0.05em;
}


/* EDUCATION */
.edu-wrap { display: flex; flex-direction: column; gap: 1.5rem; max-width: 700px; }
.edu-card {
  background: var(--bg2); border: 1px solid var(--border);
  border-radius: 12px; padding: 2rem;
  display: flex; gap: 1.5rem; align-items: flex-start;
  transition: border-color 0.2s;
}
.edu-card:hover { border-color: rgba(79,255,176,0.15); }
.edu-year-badge {
  background: rgba(79,255,176,0.06); border: 1px solid rgba(79,255,176,0.15);
  color: var(--accent); padding: 0.5rem 1rem;
  border-radius: 6px; font-size: 0.72rem; letter-spacing: 0.08em;
  white-space: nowrap; flex-shrink: 0;
}
.edu-name {
  font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700;
  color: var(--text); margin-bottom: 0.4rem;
}
.edu-degree { font-size: 0.78rem; color: var(--accent2); margin-bottom: 0.3rem; }
.edu-loc { font-size: 0.72rem; color: var(--muted2); }

/* CONTACT */
.contact-section { background: var(--bg2); }
.contact-inner { max-width: 680px; }
.contact-headline {
  font-family: 'Syne', sans-serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800; letter-spacing: -0.03em;
  margin-bottom: 1rem;
}
.contact-headline span { color: var(--accent); }
.contact-sub { font-size: 0.82rem; color: var(--muted2); line-height: 1.8; margin-bottom: 3rem; }
.contact-links { display: flex; flex-direction: column; gap: 0.8rem; }
.contact-link {
  display: flex; align-items: center; justify-content: space-between;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 10px; padding: 1.2rem 1.5rem;
  text-decoration: none; color: var(--text);
  transition: all 0.2s;
}
.contact-link:hover { border-color: rgba(79,255,176,0.2); transform: translateX(4px); }
.contact-link-left { display: flex; align-items: center; gap: 1rem; }
.contact-link-icon {
  width: 36px; height: 36px; border-radius: 8px;
  background: rgba(79,255,176,0.06); border: 1px solid rgba(79,255,176,0.12);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.9rem; flex-shrink: 0;
}
.contact-link-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.2rem; }
.contact-link-value { font-size: 0.82rem; color: var(--text); }
.contact-link-arrow { font-size: 0.9rem; color: var(--muted); transition: color 0.2s; }
.contact-link:hover .contact-link-arrow { color: var(--accent); }

/* FOOTER */
footer {
  padding: 2rem 5rem;
  border-top: 1px solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  font-size: 0.7rem; color: var(--muted);
}
.footer-name { color: var(--accent); }

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}
.reveal { opacity: 0; transform: translateY(20px); transition: all 0.6s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

@media (max-width: 900px) {
  nav { padding: 1rem 1.5rem; }
  .nav-links, .nav-cta { display: none; }
  .hero, section { padding: 4rem 1.5rem; }
  .hero { padding-top: 6rem; min-height: auto; padding-bottom: 5rem; }
  .about-grid { grid-template-columns: 1fr; gap: 3rem; }
  .skills-wrap { grid-template-columns: 1fr 1fr; }
  .projects-grid { grid-template-columns: 1fr; }
  .proj-featured { grid-column: 1; }
  footer { padding: 2rem 1.5rem; flex-direction: column; gap: 0.5rem; }
  .hero-scroll { display: none; }
}
</style>
</head>
<body>

<div class="cursor" id="cursor"></div>
<div class="cursor-ring" id="cursorRing"></div>

<nav>
  <div class="nav-logo">HR_</div>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#skills">Skills</a></li>
    <li><a href="#projects">Projects</a></li>
    <li><a href="#education">Education</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="data:application/pdf;base64," download="Hasnain_Rathod_Resume.pdf" class="nav-cv">⬇ CV</a>
</nav>

<!-- HERO -->
<section class="hero" id="home">
  <div class="hero-bg-lines"></div>
  <div class="hero-bg-circle"></div>
  <div class="hero-bg-circle2"></div>
  <div class="hero-left">
    <div class="hero-status">
      <span class="status-dot"></span>
      Available for Internship
    </div>
    <h1 class="hero-name">
      <span class="line1">Hasnain</span>
      <span class="line2">Rathod</span>
    </h1>
    <p class="hero-tagline">Aspiring Developer — <span>CSE @ LJU, Ahmedabad</span></p>
    <p class="hero-desc">
      Computer Science Engineering student passionate about building real-world projects.
      Exploring Full-Stack Development, AI, and Machine Learning. Strong in Java, Python,
      and the MERN stack — continuously improving problem-solving skills.
    </p>
    <div class="hero-actions">
      <a href="#projects" class="btn-main">View Projects →</a>
      <a href="data:application/pdf;base64," download="Hasnain_Rathod_Resume.pdf" class="btn-cv">⬇ Download CV</a>
      <a href="https://github.com/HASNAINRATHOD01/" target="_blank" class="btn-ghost">GitHub ↗</a>
      <a href="#contact" class="btn-ghost">Contact</a>
    </div>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    Scroll to explore
  </div>
</section>

<!-- ABOUT -->
<section class="about-section reveal" id="about">
  <div class="sec-eyebrow">About Me</div>
  <h2 class="sec-title">Who I Am</h2>
  <div class="about-grid">
    <div class="about-text">
      <p>Hi! I'm <strong>Hasnain Rathod</strong>, a 2nd year Computer Science Engineering student at LJ Institute of Engineering and Technology, Ahmedabad.</p>
      <p>I enjoy learning software development and building real-world projects. My core strengths include <strong>Java</strong>, <strong>Python</strong>, and <strong>Full-Stack Web Development</strong> with the MERN stack.</p>
      <p>Currently exploring <strong>AI integration</strong>, Machine Learning, and how to ship products that solve real problems. I started using GitHub from Semester 1 and love documenting my growth as a developer.</p>
    </div>
    <div class="about-stats">
      <div class="stat-box">
        <div class="stat-num">4+</div>
        <div class="stat-label">Projects Built</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">2nd</div>
        <div class="stat-label">Year CSE Student</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">MERN</div>
        <div class="stat-label">Stack Developer</div>
      </div>
      <div class="stat-box">
        <div class="stat-num">2028</div>
        <div class="stat-label">Graduating Year</div>
      </div>
    </div>
  </div>
</section>

<!-- SKILLS -->
<section id="skills" class="reveal">
  <div class="sec-eyebrow">Technical Skills</div>
  <h2 class="sec-title">What I Know</h2>
  <div class="skills-wrap">
    <div class="skill-box">
      <div class="skill-cat">Languages</div>
      <div class="tags">
        <span class="tag">Java</span>
        <span class="tag">Python</span>
        <span class="tag">JavaScript</span>
        <span class="tag">C</span>
      </div>
    </div>
    <div class="skill-box">
      <div class="skill-cat">Frontend</div>
      <div class="tags">
        <span class="tag">React.js</span>
        <span class="tag">HTML5</span>
        <span class="tag">CSS3</span>
        <span class="tag">Vite</span>
      </div>
    </div>
    <div class="skill-box">
      <div class="skill-cat">Backend</div>
      <div class="tags">
        <span class="tag">Node.js</span>
        <span class="tag">Express.js</span>
        <span class="tag">REST API</span>
        <span class="tag">Mongoose</span>
      </div>
    </div>
    <div class="skill-box">
      <div class="skill-cat">Database</div>
      <div class="tags">
        <span class="tag">MongoDB</span>
        <span class="tag">MySQL</span>
        <span class="tag">DBMS</span>
      </div>
    </div>
    <div class="skill-box">
      <div class="skill-cat">Core CS</div>
      <div class="tags">
        <span class="tag">DSA</span>
        <span class="tag">OOPs</span>
        <span class="tag">OS Basics</span>
        <span class="tag">CN Basics</span>
      </div>
    </div>
    <div class="skill-box">
      <div class="skill-cat">Tools</div>
      <div class="tags">
        <span class="tag">Git</span>
        <span class="tag">GitHub</span>
        <span class="tag">VS Code</span>
        <span class="tag">Postman</span>
      </div>
    </div>
  </div>
</section>

<!-- PROJECTS -->
<section class="projects-section reveal" id="projects">
  <div class="sec-eyebrow">Projects</div>
  <h2 class="sec-title">What I've Built</h2>
  <div class="projects-grid">

      <div class="proj-card">
      <div class="proj-header">
        <span class="proj-num">01</span>
        <a href="https://github.com/HASNAINRATHOD01/HMS" target="_blank" class="proj-arrow">↗</a>
      </div>
      <div class="proj-title">Hotel Management System</div>
      <p class="proj-desc">A web-based system to manage hotel operations — room booking, guest check-in/check-out, and billing with a clean responsive UI.</p>
      <div class="proj-tech">
        <span>HTML</span><span>CSS</span><span>JavaScript</span>
      </div>
    </div>

    <div class="proj-card">
      <div class="proj-header">
        <span class="proj-num">02</span>
        <a href="https://github.com/HASNAINRATHOD01/Pharmacy-Management-System" target="_blank" class="proj-arrow">↗</a>
